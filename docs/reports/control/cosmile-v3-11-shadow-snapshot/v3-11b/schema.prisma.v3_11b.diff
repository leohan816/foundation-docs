+// ★V3-11B Learning Commerce Memory — 신규 model 3종(D-1·commerce/outcome 계층). CHECK/XOR/FK는 migration SQL 집행.
+model RecommendationEvent {
+  recommendationId String   @id                         // rec_v3_+ULID26·CHECK(형식)
+  eventType        String                               // 5값(V3-03)·CHECK
+  subjectRef       String?                              // subject_ref XOR anonymous_ref·CHECK
+  anonymousRef     String?                              // ★commerce 계층 전용(memory 직접 유입 금지)
+  sessionId        String
+  productId        String
+  skuId            String?
