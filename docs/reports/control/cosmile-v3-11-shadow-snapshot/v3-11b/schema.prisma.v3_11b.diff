+  createdAt        DateTime @default(now()) @db.Timestamptz(6) // ★문자열 정렬 금지
+  @@index([subjectRef])
+  @@index([anonymousRef])
+}
+
+model RecOutcomeEvent {
+  id               String   @id                         // 생성 id
